.fortune-wrap { padding: 24rpx; }

.rating-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.label { font-size: 28rpx; color: #666; margin-right: 16rpx; }

.star { font-size: 36rpx; color: #FAAD14; }
.star.empty { color: #EEE; }

.lucky-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.lucky-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lucky-label { font-size: 22rpx; color: #BBB; margin-bottom: 8rpx; }

.lucky-val { font-size: 32rpx; font-weight: 700; color: #6B5CE7; }
.lucky-val.number { font-size: 48rpx; }

.tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.content {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  white-space: pre-wrap;
}

.meta {
  margin-top: 8rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.meta-row:last-child { border-bottom: none; }

.meta-label { color: #999; font-size: 26rpx; }
.meta-val { color: #333; font-size: 26rpx; font-weight: 500; }
