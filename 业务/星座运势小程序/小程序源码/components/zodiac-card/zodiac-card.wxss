.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}

.card:active {
  transform: scale(0.95);
}

.card.no-data {
  opacity: 0.5;
}

.icon { font-size: 52rpx; margin-bottom: 8rpx; }

.name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.dates {
  font-size: 18rpx;
  color: #BBB;
  margin-bottom: 8rpx;
}

.stars { display: flex; }

.star {
  font-size: 18rpx;
  color: #FAAD14;
}

.star.empty { color: #EEE; }

.hint {
  font-size: 18rpx;
  color: #CCC;
}
