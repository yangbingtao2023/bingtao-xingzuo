/* 运势详情页样式 */
.page {
  min-height: 100vh;
  background: #F5F5F5;
}

.top-bar {
  background: #6B5CE7;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  margin-right: 16rpx;
  line-height: 1;
}

.sign-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-text {
  color: #999;
  font-size: 26rpx;
  margin-top: 24rpx;
}

.loading-spinner {
  font-size: 64rpx;
}

/* 错误 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  color: #999;
}

/* 幸运元素 */
.lucky-section {
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.rating-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.star {
  font-size: 24rpx;
  color: #FAAD14;
}

.star.empty {
  color: #EEEEEE;
}

.star.big {
  font-size: 36rpx;
}

.lucky-elements {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.lucky-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lucky-label {
  font-size: 22rpx;
  color: #BBBBBB;
  margin-bottom: 8rpx;
}

.lucky-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #6B5CE7;
}

.lucky-value.number {
  font-size: 48rpx;
}

.tags-row {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.tag-item {
  display: inline-block;
  margin: 0 4rpx;
  padding: 4rpx 16rpx;
  background: #6B5CE7;
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 22rpx;
}

/* 运势正文 */
.content-card {
  background: #FFFFFF;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.content-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.content-body {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 星座信息 */
.info-card {
  background: #FFFFFF;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #999;
  font-size: 26rpx;
}

.info-value {
  color: #333;
  font-size: 26rpx;
  font-weight: 500;
}

/* 广告 */
.ad-placeholder {
  color: #CCCCCC;
  font-size: 22rpx;
}
