/* 首页样式 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #6B5CE7 0%, #8B7FE8 200rpx, #F5F5F5 400rpx);
}

.header {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
  color: #FFFFFF;
}

.header-date {
  display: block;
  font-size: 26rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  opacity: 0.7;
}

/* 骨架屏 */
.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
}

.skeleton-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.skeleton-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #EEEEEE;
  margin-bottom: 12rpx;
}

.skeleton-text {
  width: 80rpx;
  height: 24rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  color: #999999;
  margin-bottom: 32rpx;
}

.retry-btn {
  background: #6B5CE7;
  color: #FFFFFF;
  border-radius: 32rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

/* 星座网格 */
.zodiac-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 16rpx 8rpx;
}

.zodiac-card {
  width: calc(25% - 16rpx);
  margin: 8rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.zodiac-card:active {
  transform: scale(0.95);
}

.zodiac-card.no-data {
  opacity: 0.6;
}

.zodiac-icon {
  font-size: 52rpx;
  margin-bottom: 8rpx;
}

.zodiac-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.zodiac-dates {
  font-size: 18rpx;
  color: #BBBBBB;
  margin-bottom: 8rpx;
}

.rating-stars {
  display: flex;
}

.star {
  font-size: 18rpx;
  color: #FAAD14;
}

.star.empty {
  color: #EEEEEE;
}

.no-data-hint {
  font-size: 18rpx;
  color: #CCCCCC;
}

/* 广告占位 */
.ad-placeholder {
  color: #CCCCCC;
  font-size: 22rpx;
}
