<!-- 首页：12 星座运势网格 -->
<view class="page">
  <!-- 日期头部 -->
  <view class="header">
    <text class="header-date">{{date}}</text>
    <text class="header-title">每日星座运势</text>
    <text class="header-sub">点击你的星座，查看今日运势</text>
  </view>

  <!-- 加载骨架屏 -->
  <view wx:if="{{loading}}" class="skeleton-grid">
    <view class="skeleton-item" wx:for="{{12}}" wx:key="index">
      <view class="skeleton-icon"></view>
      <view class="skeleton-text"></view>
    </view>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-state">
    <text class="error-icon">😵</text>
    <text class="error-text">{{errorMsg}}</text>
    <button class="retry-btn" bindtap="loadFortunes">重新加载</button>
  </view>

  <!-- 星座网格 -->
  <view wx:else class="zodiac-grid">
    <view
      class="zodiac-card {{item.hasData ? '' : 'no-data'}}"
      wx:for="{{signs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onTapSign"
    >
      <text class="zodiac-icon">{{item.icon}}</text>
      <text class="zodiac-name">{{item.name}}</text>
      <text class="zodiac-dates">{{item.dateRange}}</text>
      <view wx:if="{{item.rating > 0}}" class="rating-stars">
        <text wx:for="{{item.rating}}" wx:key="*this" class="star">★</text>
        <text wx:for="{{5 - item.rating}}" wx:key="*this" class="star empty">★</text>
      </view>
      <text wx:else class="no-data-hint">加载中</text>
    </view>
  </view>

  <!-- 广告位 -->
  <view class="ad-container">
    <!-- 流量主广告（UV >= 1000 后启用） -->
    <!-- <ad unit-id="adunit-xxxxxxxxxxxx" ad-type="banner" bindload="onAdLoad" binderror="onAdError"></ad> -->
    <text class="ad-placeholder">广告位</text>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-area-bottom" style="height: 24rpx;"></view>
</view>
